# Portal-only local development (apps/portal)
# Copy to .env.local and adjust values as needed.

# Required for Prisma when running outside Docker.
DATABASE_URL=postgresql://postgres:postgres_password_change_me@localhost:5432/teamflow?schema=portal

# Optional for local auth stability across restarts.
# If omitted on localhost, the app uses a development fallback secret.
NEXTAUTH_SECRET=replace-with-a-long-random-secret-for-portal

# Optional service embeds/API integrations.
# For iframe-friendly local dev with docker-compose proxy services.
N8N_EDITOR_URL=http://localhost:5680
LANGFUSE_URL=http://localhost:3002
N8N_API_KEY=replace-with-your-n8n-api-key
