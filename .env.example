# ══════════════════════════════════════════════════════════════
# TeamFlow Environment Variables
# Copy to .env and update values before running.
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_change_me
POSTGRES_DB=teamflow

# ── Portal ──
PORTAL_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-with-a-long-random-secret-for-portal
# For portal dev outside Docker, also set:
# DATABASE_URL=postgresql://postgres:postgres_password_change_me@localhost:5432/teamflow?schema=portal

# ── n8n ──
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_URL=http://localhost:5678
N8N_API_KEY=replace-with-your-n8n-api-key

# ── Langfuse ──
LANGFUSE_URL=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=replace-with-a-long-random-secret
LANGFUSE_SALT=replace-with-a-long-random-secret

# ── ClickHouse ──
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=langfuse_clickhouse_password_change_me

# ── MinIO (S3-compatible object store) ──
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_password_change_me
LANGFUSE_S3_BUCKET=langfuse
LANGFUSE_S3_REGION=us-east-1

# ── Langfuse Init (first-run bootstrap) ──
LANGFUSE_INIT_ORG_ID=teamflow
LANGFUSE_INIT_ORG_NAME=TeamFlow
LANGFUSE_INIT_PROJECT_ID=teamflow-shared
LANGFUSE_INIT_PROJECT_NAME=TeamFlow Shared Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-replace-this-public-key
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-replace-this-secret-key
LANGFUSE_INIT_USER_EMAIL=admin@teamflow.local
LANGFUSE_INIT_USER_NAME=TeamFlow Admin
LANGFUSE_INIT_USER_PASSWORD=replace-with-a-strong-password

# ── General ──
TIMEZONE=UTC

# ══════════════════════════════════════════════════════════════
# Vercel Preview Deployments
# ──────────────────────────────────────────────────────────────
# When deploying to Vercel, only these are required:
#   DATABASE_URL     = your Neon connection string
#   NEXTAUTH_SECRET  = any random 32+ char string
#
# Optional for remote service embeds:
#   N8N_EDITOR_URL   = https://your-n8n-instance.com
#   LANGFUSE_URL     = https://your-langfuse-instance.com
#   N8N_API_KEY      = your n8n API key
# ══════════════════════════════════════════════════════════════
