# TeamFlow Worker Configuration
# Copy to .env and update values.

# ─── Portal Connection ───────────────────────────────────────
PORTAL_URL=http://localhost:3001
WORKER_API_KEY=replace-with-portal-worker-api-key
WORKER_NAME=my-dev-machine
WORKER_PORT=9800
WORKER_CAPABILITIES=code-gen,review,feedback

# ─── GitHub (required for code-gen tasks) ────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=davidminin/teamflow

# ─── LLM (at least one required for code-gen) ───────────────
# Local Ollama (recommended — free)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI-compatible (vLLM, Together, OpenRouter)
# LLM_API_URL=http://localhost:8000/v1
# LLM_API_KEY=
# LLM_MODEL=meta-llama/Llama-3.1-8B

# Cloud fallback
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── ClickUp (optional — for MCP tools) ─────────────────────
# CLICKUP_API_TOKEN=pk_...
# CLICKUP_LIST_ID=your_list_id
